generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String

  questions Question[]
  attempts  Attempt[]
}

model Question {
  id       Int     @id @default(autoincrement())
  question String
  answer   String
  imageUrl String? @db.VarChar(255)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  keywords Keyword[]
  attempts Attempt[]
}

model Keyword {
  id   Int    @id @default(autoincrement())
  name String @unique

  questions Question[]
}

model Attempt {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  userId          Int
  questionId      Int
  submittedAnswer String   @db.VarChar(255)
  correctAnswer   String   @db.VarChar(255)
  correct         Boolean

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@map("attempts")
}